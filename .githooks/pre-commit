#!/bin/bash
#
# Pre-commit hook for sandctl
# Runs linting and tests on staged TypeScript files
#

set -euo pipefail

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Print colored message
print_error() {
    echo -e "${RED}ERROR:${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}WARNING:${NC} $1"
}

print_success() {
    echo -e "${GREEN}✓${NC} $1"
}

print_header() {
    echo -e "\n${YELLOW}▶${NC} $1"
}

# Check for required tools
check_bun() {
    if ! command -v bun &> /dev/null; then
        print_error "bun is not installed or not in PATH"
        echo "Please install Bun from https://bun.sh/"
        exit 1
    fi
}

# Get staged TypeScript files (Added, Copied, Modified - not Deleted)
get_staged_ts_files() {
    git diff --cached --name-only --diff-filter=ACM | grep '\.ts$' || true
}

# Main execution
main() {
    # Get staged TypeScript files
    STAGED_TS_FILES=$(get_staged_ts_files)

    # Exit early if no TypeScript files are staged
    if [ -z "$STAGED_TS_FILES" ]; then
        echo "No TypeScript files staged, skipping checks"
        exit 0
    fi

    # Check for required tools
    check_bun

    echo "Running pre-commit checks on staged TypeScript files..."

    # Track if any check fails
    FAILED=0

    # Check 1: TypeScript lint
    print_header "Running linters..."
    if ! bun run lint 2>&1; then
        print_error "Lint found issues"
        FAILED=1
    else
        print_success "Linting passed"
    fi

    # Check 2: TypeScript tests
    print_header "Running tests..."
    if ! bun run test 2>&1; then
        print_error "Tests failed"
        FAILED=1
    else
        print_success "Tests passed"
    fi

    # Final result
    echo ""
    if [ $FAILED -ne 0 ]; then
        print_error "Pre-commit checks failed. Please fix the issues above."
        echo ""
        echo "To bypass this hook (emergency only): git commit --no-verify"
        exit 1
    fi

    print_success "All pre-commit checks passed!"
    exit 0
}

main "$@"
