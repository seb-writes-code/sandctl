    "luxon": "^3.7.2",
    "ora": "^9.0.0",
    "ssh2": "^1.17.0",
    "validator": "^13.15.26",
    "yaml": "^2.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@types/node": "^24.3.0",
    "@types/ssh2": "^1.15.5",
    "bun-types": "^1.2.22",
    "typescript": "^5.9.2"
